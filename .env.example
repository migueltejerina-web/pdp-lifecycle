# HubSpot (PDP lifecycle — pagos señal/arras)
# Private App → Settings > Integrations > Private Apps
# Scopes: crm.objects.deals.read, crm.objects.custom.read (listings 0-420)
HUBSPOT_PRIVATE_APP_TOKEN=

# IDs para testear prop_001 (deal opportunity + listing asociado)
HUBSPOT_MOCK_DEAL_ID=495605739736
# HUBSPOT_MOCK_LISTING_ID=1156018536637

# Google Form — poder notarial online (pre-relleno desde HubSpot)
# 1. Abre el Form → ⋮ → "Obtener enlace pre-rellenado" → rellena campos de prueba → copia el enlace
# 2. GOOGLE_FORM_PODER_NOTARIAL_URL = URL base del form (hasta viewform)
# 3. GOOGLE_FORM_PODER_NOTARIAL_ENTRY_MAP = JSON: clave interna → entry.XXXXX del enlace
# Claves soportadas: fullName, email, phone, nif (→ client_national_id en HubSpot), iban, contactAddress, contactCity,
# propertyAddress, propertyCity, propertyCountry, propertyName, purchasePrice, notaryName,
# hubspotDealId, hubspotListingId, taxlandNumber
# GOOGLE_FORM_PODER_NOTARIAL_URL=https://docs.google.com/forms/d/e/FORM_ID/viewform
# GOOGLE_FORM_PODER_NOTARIAL_ENTRY_MAP={"fullName":"entry.111","email":"entry.222","propertyAddress":"entry.333"}
# Opcional — entry IDs de preguntas extra (Compra solo, %, activo esencial, upload nota simple en Google):
# GOOGLE_FORM_PODER_NOTARIAL_EXTRA_ENTRY_MAP={"buyingAlone":"entry.XXX","ownershipPercentage":"entry.XXX","essentialCompanyAsset":"entry.XXX"}

# PropHero Portfolio API — HTTP Basic auth for TECH URL fields (nota simple, FEIN, etc.)
# Server-only; never use NEXT_PUBLIC_ prefix.
# PORTFOLIO_API_BASE_URL=https://api.portfolio.prod.prophero.com
# PORTFOLIO_API_USERNAME=
# PORTFOLIO_API_PASSWORD=
