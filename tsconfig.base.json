{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@vistral/ui": ["packages/ui/src"],
      "@vistral/ui/*": ["packages/ui/src/*"],
      "@vistral/db": ["packages/db/src"],
      "@vistral/db/*": ["packages/db/src/*"],
      "@vistral/auth": ["packages/auth/src"],
      "@vistral/auth/*": ["packages/auth/src/*"],
      "@vistral/config": ["packages/config/src"],
      "@vistral/config/*": ["packages/config/src/*"],
      "@vistral/types": ["packages/types/src"],
      "@vistral/types/*": ["packages/types/src/*"]
    }
  }
}
